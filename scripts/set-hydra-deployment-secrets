#!/usr/bin/env bash

set -euo pipefail
umask 077

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
secrets_file="$repo_root/secrets/hydra.yaml"
tunnel_credentials_file="${CLOUDFLARE_TUNNEL_CREDENTIALS_FILE:-}"
hydra_admin_password="${HYDRA_ADMIN_PASSWORD:-}"

required_variables=(
  R2_ACCOUNT_ID
  R2_ACCESS_KEY_ID
  R2_SECRET_ACCESS_KEY
  CLOUDFLARE_TUNNEL_CREDENTIALS_FILE
)

for variable in "${required_variables[@]}"; do
  if [[ -z "${!variable:-}" ]]; then
    printf 'Required environment variable is not set: %s\n' "$variable" >&2
    exit 1
  fi
done

if [[ ! "$R2_ACCOUNT_ID" =~ ^[0-9a-fA-F]{32}$ ]]; then
  echo "R2_ACCOUNT_ID must be a 32-character hexadecimal Cloudflare account ID" >&2
  exit 1
fi

if [[ ${#R2_ACCESS_KEY_ID} -lt 16 || "$R2_ACCESS_KEY_ID" == *CHANGE_ME* ]]; then
  echo "R2_ACCESS_KEY_ID must be a real R2 access key of at least 16 characters" >&2
  exit 1
fi

if [[ ${#R2_SECRET_ACCESS_KEY} -lt 16 || "$R2_SECRET_ACCESS_KEY" == *CHANGE_ME* ]]; then
  echo "R2_SECRET_ACCESS_KEY must be a real R2 secret key of at least 16 characters" >&2
  exit 1
fi

if [[ -n "$hydra_admin_password" &&
  (${#hydra_admin_password} -lt 32 || "$hydra_admin_password" == *CHANGE_ME*) ]]; then
  echo "HYDRA_ADMIN_PASSWORD must contain at least 32 characters" >&2
  exit 1
fi

if [[ ! -r "$tunnel_credentials_file" ]]; then
  echo "Tunnel credentials file is not readable: $tunnel_credentials_file" >&2
  exit 1
fi

tunnel_credentials="$({
  jq -ce '
    select(
      (.AccountTag | type == "string" and length > 0) and
      (.TunnelID | test("^[0-9a-fA-F-]{36}$")) and
      (.TunnelSecret | type == "string" and length > 0) and
      (tostring | contains("CHANGE_ME") | not)
    )
  ' "$tunnel_credentials_file"
} || {
  echo "Tunnel credentials JSON is invalid" >&2
  exit 1
})"

sops_packages=(
  "path:$repo_root#nixosConfigurations.biuh-lab.pkgs.sops"
  "path:$repo_root#nixosConfigurations.biuh-lab.pkgs.age-plugin-yubikey"
)

if [[ -z "${SOPS_AGE_KEY_CMD:-}" && -r "${HOME}/.ssh/id_ed25519" ]]; then
  export SOPS_AGE_KEY_CMD="nix shell path:$repo_root#nixosConfigurations.biuh-lab.pkgs.ssh-to-age -c ssh-to-age -private-key -i ${HOME}/.ssh/id_ed25519"
fi

sops_run() {
  nix shell "${sops_packages[@]}" -c sops "$@"
}

set_secret() {
  local key="$1"
  local value="$2"

  printf '%s' "$value" \
    | jq -Rs . \
    | sops_run set --value-stdin "$secrets_file" "[\"$key\"]"
}

set_secret r2-account-id "$R2_ACCOUNT_ID"
set_secret r2-access-key-id "$R2_ACCESS_KEY_ID"
set_secret r2-secret-access-key "$R2_SECRET_ACCESS_KEY"
set_secret cloudflare-tunnel-credentials "$tunnel_credentials"

if [[ -n "$hydra_admin_password" ]]; then
  set_secret hydra-admin-password "$hydra_admin_password"
fi

sops_run --decrypt --output-type json "$secrets_file" \
  | jq -e '
      (."r2-account-id" | test("^[0-9a-fA-F]{32}$")) and
      (."r2-access-key-id" | length >= 16 and (contains("CHANGE_ME") | not)) and
      (."r2-secret-access-key" | length >= 16 and (contains("CHANGE_ME") | not)) and
      (."hydra-admin-password" | length >= 32 and (contains("CHANGE_ME") | not)) and
      (."hydra-cache-signing-key" | startswith("cache.leak.moe-1:")) and
      (."cloudflare-tunnel-credentials" | fromjson | .TunnelID | test("^[0-9a-fA-F-]{36}$"))
    ' >/dev/null

echo "Hydra deployment secrets updated and validated."
